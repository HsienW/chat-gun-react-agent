VITE_LANGGRAPH_API_URL=

# Image upload / recognition preflight
VITE_IMAGE_UPLOAD_MAX_FILES=6
VITE_IMAGE_UPLOAD_MAX_BYTES=5242880
VITE_IMAGE_UPLOAD_MAX_CONCURRENT=2
VITE_IMAGE_UPLOAD_MAX_PIXELS=24000000
VITE_IMAGE_UPLOAD_ALLOWED_EXTENSIONS=.png,.jpg,.jpeg,.webp
VITE_IMAGE_UPLOAD_ALLOWED_MIME_TYPES=image/png,image/jpeg,image/webp
# Reserved for future object storage uploads. Empty means image data is passed through the request after preflight.
VITE_IMAGE_UPLOAD_S3_BUCKET_URL=
