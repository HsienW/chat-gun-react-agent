# Gen AI Provider 設定
# Default: Qwen / Alibaba Cloud Bailian OpenAI-compatible runtime.
# Never commit real credentials. Use environment variables or a local untracked .env.
LLM_PROVIDER=qwen
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_CHAT_MODEL=qwen-plus
QWEN_RESEARCH_MODEL=qwen-plus
QWEN_VISION_MODEL=qwen-vl-plus
QWEN_TOOL_MODEL=qwen-plus
DEFAULT_MODEL=qwen-plus
CHAT_MODEL=qwen-plus
MATH_MODEL=qwen-plus
MCP_AGENT_MODEL=qwen-plus
# Live smoke is opt-in and skipped by default.
RUN_QWEN_LIVE_SMOKE=false

# Optional compatibility providers. These are not the default runtime path.
# CCR backend planner settings.
# Example: CCR_BASE_URL=http://127.0.0.1:3456/v1
CCR_BASE_URL=
CCR_API_KEY=
CCR_PROVIDER=deepseek
CCR_MODEL=
# OpenAI-compatible aliases are also supported when LLM_PROVIDER=openai-compatible:
# OPENAI_COMPATIBLE_BASE_URL= / OPENAI_COMPATIBLE_API_KEY= / OPENAI_COMPATIBLE_MODEL=
# OPENAI_BASE_URL= / OPENAI_API_KEY= / OPENAI_MODEL=
LANGSMITH_API_KEY=your_langsmith_api_key
REDIS_URI=redis_uri
POSTGRES_URI=postgres_uri

# MCP Server 設定
MCP_LOAD_ON_START=false
DEEP_RESEARCHER_MCP_ENABLED=false
MCP_FILESYSTEM_ENABLED=true
MCP_BRAVE_SEARCH_ENABLED=false
MCP_FILESYSTEM_PATH=your_filesystem_path
# Restrict MCP filesystem roots. Use OS path delimiter for multiple roots.
# Windows example: C:\D\ai-agent\chat-gun-react-agent\backend;C:\D\safe-data
# Linux/macOS example: /app/backend:/app/safe-data
MCP_FILESYSTEM_ALLOWED_ROOTS=
BRAVE_API_KEY=your_brave_api_key_here

# Native external tools
# TAVILY_API_KEY is required by the built-in web_search tool.
# BRAVE_API_KEY is only used by the optional Brave MCP server.
TAVILY_API_KEY=your_tavily_api_key_here
# Mapbox Geocoding v6 resolves locations. Open-Meteo remains the weather data provider.
# Keep the token in the Backend secret store; never expose it to Browser or BFF responses.
MAPBOX_ACCESS_TOKEN=
# temporary (default) does not persist Mapbox-derived candidates or coordinates.
# permanent requires an account/token with Permanent Geocoding entitlement.
MAPBOX_GEOCODING_STORAGE_MODE=temporary
# Optional product/deployment policy. Empty means omit the parameter and use Provider default.
# Allowed: ar,cn,in,jp,ma,rs,ru,tr,us
MAPBOX_WORLDVIEW=

# Weather tool structured result — enabled by default after generalize-weather-location-resolution
WEATHER_STRUCTURED_RESULT_ENABLED=true

# Weather location resolution settings
# Maximum characters for location input
WEATHER_LOCATION_MAX_CHARS=160
# Maximum geocoding query variants to try
WEATHER_GEOCODING_MAX_QUERIES=3
# Maximum network attempts across query variants, including retries
WEATHER_GEOCODING_MAX_ATTEMPTS=4
# Maximum candidates returned from geocoding provider
WEATHER_GEOCODING_MAX_CANDIDATES=10
# Minimum score for a candidate to be considered found
WEATHER_GEOCODING_MIN_SCORE=35
# Score difference below which ambiguity is declared
WEATHER_GEOCODING_AMBIGUITY_DELTA=8
# Timeout for geocoding requests (ms)
WEATHER_GEOCODING_TIMEOUT_MS=5000
# Total location-resolution budget, including queue wait and retry backoff
WEATHER_GEOCODING_TOTAL_BUDGET_MS=8000
# Process-local traffic governor. This is not a cross-replica global limit.
WEATHER_GEOCODING_RATE_LIMIT_PER_INSTANCE_PER_MINUTE=100
WEATHER_GEOCODING_MAX_CONCURRENCY=10
WEATHER_GEOCODING_QUEUE_MAX=100
WEATHER_GEOCODING_CIRCUIT_FAILURE_THRESHOLD=5
WEATHER_GEOCODING_CIRCUIT_COOLDOWN_MS=60000
# Timeout for forecast requests (ms)
WEATHER_FORECAST_TIMEOUT_MS=8000
# Dev/test-only manual verification switches. Ignored when NODE_ENV or APP_ENV is production.
WEATHER_TEST_FORCE_GEOCODING_ERROR=false
WEATHER_TEST_FORCE_FORECAST_ERROR=false
# Test fixtures only; ignored in production. Product and live paths use Mapbox.
WEATHER_TEST_GEOCODING_PROVIDER=

# Image upload / recognition preflight
BACKEND_IMAGE_UPLOAD_MAX_FILES=6
BACKEND_IMAGE_UPLOAD_MAX_BYTES=5242880
BACKEND_IMAGE_UPLOAD_MAX_PIXELS=24000000
BACKEND_IMAGE_UPLOAD_ALLOWED_EXTENSIONS=.png,.jpg,.jpeg,.webp
BACKEND_IMAGE_UPLOAD_ALLOWED_MIME_TYPES=image/png,image/jpeg,image/webp
# Reserved for future object storage uploads. Empty means image data is passed through the request after preflight.
BACKEND_IMAGE_UPLOAD_S3_BUCKET_URL=

# Tool security governance
# TOOL_ALLOWLIST restricts available tools when non-empty. TOOL_DENYLIST always blocks listed tools.
# Examples: TOOL_ALLOWLIST=calculator_tool,web_search,web_fetch,current_weather
TOOL_AUDIT_ENABLED=true
TOOL_ALLOWLIST=
TOOL_DENYLIST=
TOOL_TIMEOUT_MS=15000
TOOL_MAX_INPUT_CHARS=8000
TOOL_MAX_OUTPUT_CHARS=24000
# Per-tool overrides use normalized names, for example:
# TOOL_WEB_FETCH_TIMEOUT_MS=12000
# TOOL_WEB_FETCH_MAX_OUTPUT_CHARS=12000
# TOOL_WEB_FETCH_ENABLED=true

# web_fetch isolation
# Defaults to 80,443. Add ports only when the deployment explicitly needs them.
WEB_FETCH_ALLOWED_PORTS=80,443

# Optional outbound HTTP proxy for Node fetch / provider API calls.
# Example: HTTPS_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=
HTTP_PROXY=
NO_PROXY=localhost,127.0.0.1
